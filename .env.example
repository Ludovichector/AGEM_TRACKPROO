# =====================================================
# AGEM TrackPro — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs
# =====================================================

# Base de données PostgreSQL (Supabase)
# Pooler URL — runtime (avec pgbouncer)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct URL — migrations Prisma uniquement
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# NextAuth.js v5 — OBLIGATOIRE
# Générer avec : openssl rand -base64 32
AUTH_SECRET="CHANGEZ_MOI_32_CHARS_MINIMUM"

# Environnement
NODE_ENV="production"
